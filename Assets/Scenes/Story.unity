  m_Script: {fileID: 11500000, guid: bb84645204de1504ca41431b6a97e8d8, type: 3}
  m_Name: 
  m_EditorClassIdentifier: 
  images:
  - {fileID: 844206038}
  - {fileID: 753940636}
  - {fileID: 1483092284}
  - {fileID: 564243462}
  audioClips:
  - {fileID: 8300000, guid: 41d0432c808967043be814e111afe1ae, type: 3}
  - {fileID: 8300000, guid: 074ca8743c18e5247823f60c0469a7c6, type: 3}
  - {fileID: 8300000, guid: 34bfb0764407ce44c820136d71bedc95, type: 3}
  - {fileID: 8300000, guid: d41200adb9da38f4aba15f35ef512925, type: 3}
  textParts:
  - parts:
    - 'Narrator: In a realm shrouded by shadow, a great wizard, eager for power,
      dabbled in forbidden arts.'
    - 'Narrator: His reckless magic threatened to unravel the very fabric of existence.'
  - parts:
    - 'Narrator: From the depths of ancient lore, an elder wizard, cloaked in crimson,
      emerged.'
    - 'Narrator: With eyes that burned like embers, he cast a potent curse, binding
      the great one''s chaotic energy.'
    - 'Narrator: The misguided apprentice was consumed by his own ambition, forever
      marked by the elder''s dark decree.'
  - parts:
    - 'Narrator: The balance was restored but at a terrible cost, echoing through
      the desolate lands.'
    - 'Narrator: The echoes of the curse reverberated through the desolate lands,
      a grim reminder of unchecked ambition. '
    - 'Narrator: The elder wizard, his task complete, vanished into the shadows,
      leaving behind a world forever changed by the clash of arcane powers.'
  - parts:
    - 'Narrator: Yet, even in the restored balance, a shadow lingered. The great
      wizard, though humbled, carried the weight of his past actions, a silent testament
      to the perils of ambition.'
    - 'Narrator: And in the quiet corners of the world, whispers of his fall served
      as a constant warning, a dark melody played on the winds of fate.'
    - 'Narrator: And now his task is to find the elder wizard and break the curse.'
  textPartDurations:
  - durations:
    - 6
    - 4.5
  - durations:
    - 5
    - 6
    - 7.5
  - durations:
    - 5
    - 6
    - 8.5
  - durations:
    - 11
    - 9
    - 4
  textDisplay: {fileID: 63215687}
  textPanel: {fileID: 229655947}
  UImanager: {fileID: 652422302}
